{
  "name": "@pankajtime12/react-native-squircle-view",
  "version": "0.1.21",
  "description": "Figma-flavored squircles for React Native with gradient support — no native modules",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.tsx",
  "source": "src/index.tsx",
  "exports": {
    ".": {
      "types": "./lib/typescript/index.d.ts",
      "react-native": "./src/index.tsx",
      "default": "./lib/commonjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "clean": "del-cli lib",
    "prepare": "bob build && node scripts/fix-dts-extensions.js",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\""
  },
  "dependencies": {
    "figma-squircle": "1.1.0"
  },
  "keywords": [
    "react-native",
    "squircle",
    "figma",
    "gradient",
    "svg",
    "smooth-corners",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pankajtime123/react-native-squircle-view.git"
  },
  "author": "pankajtime12 (https://github.com/pankajtime123)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pankajtime123/react-native-squircle-view/issues"
  },
  "homepage": "https://github.com/pankajtime123/react-native-squircle-view#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.3",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@types/react": "19.2.0",
    "del-cli": "7.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-ft-flow": "3.0.11",
    "eslint-plugin-prettier": "5.5.5",
    "prettier": "3.8.1",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-builder-bob": "0.41.0",
    "react-native-reanimated": "4.4.1",
    "react-native-svg": "15.8.0",
    "turbo": "2.8.21",
    "typescript": "6.0.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": ">=3.0.0",
    "react-native-svg": "*"
  },
  "peerDependenciesMeta": {
    "react-native-reanimated": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint"
    ],
    "version": "0.62.0"
  }
}
