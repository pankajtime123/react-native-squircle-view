{
  "name": "@pankajtime12/react-native-squircle-view",
  "version": "0.1.30",
  "description": "Figma-flavored squircles for React Native with gradient support — no native modules",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.tsx",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./lib/typescript/index.d.ts",
      "react-native": "./src/index.tsx",
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "default": "./lib/commonjs/index.js"
    }
  },
  "source": "src/index.tsx",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "clean": "del-cli lib",
    "prepare": "bob build",
    "tsc": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx"
  },
  "dependencies": {
    "figma-squircle": "1.1.0"
  },
  "keywords": [
    "react-native",
    "squircle",
    "figma",
    "gradient",
    "svg",
    "smooth-corners",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pankajtime123/react-native-squircle-view.git"
  },
  "author": "pankajtime12 (https://github.com/pankajtime123)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pankajtime123/react-native-squircle-view/issues"
  },
  "homepage": "https://github.com/pankajtime123/react-native-squircle-view#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "~18.2.6",
    "babel-plugin-module-resolver": "^4.1.0",
    "del-cli": "7.0.0",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "^3.3.3",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-builder-bob": "^0.37.0",
    "react-native-reanimated": "4.4.1",
    "react-native-svg": "12.1.0",
    "turbo": "2.8.21",
    "typescript": "^5.5.4"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": ">=3.0.0",
    "react-native-svg": "*"
  },
  "peerDependenciesMeta": {
    "react-native-reanimated": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ],
    "esm": true
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint"
    ],
    "version": "0.62.0"
  }
}
